# ------------------------------------------------------------------------------
# Xetroc-AI: Variáveis de Ambiente Necessárias
# Copie este arquivo para .env e preencha com as suas credenciais
# ------------------------------------------------------------------------------

# --- IA e Modelos (LLM & Embeddings) ---
OPENAI_API_KEY=sua_chave_openai_aqui
# COHERE_API_KEY=sua_chave_cohere_aqui (Opcional, se usar Reranker da Cohere)
HUGGINGFACE_API_KEY=sua_chave_huggingface_aqui (Opcional para modelos locais)

# --- Banco de Dados SQL (PostgreSQL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=senha_segura
POSTGRES_DB=xetroc_maintenance
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Banco de Dados Vetorial (ChromaDB ou Qdrant) ---
# Se usar ChromaDB local:
CHROMA_DB_PATH=./data/vector_db
# Se usar Qdrant via Docker:
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- Orquestrador (Prefect) ---
# PREFECT_API_URL=http://localhost:4200/api
# PREFECT_API_KEY=sua_chave_prefect_cloud_aqui (Se usar Prefect Cloud)

# --- Configurações de Path ---
RAW_DATA_PATH=./data/raw_norms
PROCESSED_DATA_PATH=./data/processed
LOG_LEVEL=INFO
